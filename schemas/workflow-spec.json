{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workflow Spec",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "action": { "type": "string" },
          "scope": { "type": "string" },
          "params": { "type": "object" }
        },
        "required": ["action", "scope"]
      }
    }
  },
  "required": ["title", "steps"]
}
